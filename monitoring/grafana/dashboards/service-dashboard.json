{
  "title": "Inventory Management System",
  "tags": ["inventory"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "API Instances Up",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "count(up{job=\"inventory-api\"} == 1)", "legendFormat": "Healthy"}],
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}}
    },
    {
      "id": 7,
      "title": "Requests In Progress",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "sum(http_requests_in_progress{job=\"inventory-api\"})", "legendFormat": "In Progress"}],
      "datasource": {"type": "prometheus"}
    },
    {
      "id": 10,
      "title": "Total Requests (last 5m)",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "sum(increase(http_requests_total{job=\"inventory-api\"}[5m]))", "legendFormat": "Requests"}],
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 11,
      "title": "Error Rate (5xx)",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "sum(rate(http_requests_total{job=\"inventory-api\",status=~\"5..\"}[5m])) or vector(0)", "legendFormat": "5xx/s"}],
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps", "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.1}]}}}
    },
    {
      "id": 2,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "targets": [{"expr": "sum(rate(http_requests_total{job=\"inventory-api\"}[1m])) by (handler)", "legendFormat": "{{handler}}"}],
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 4,
      "title": "Response Status Codes",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "targets": [{"expr": "sum(rate(http_requests_total{job=\"inventory-api\"}[1m])) by (status)", "legendFormat": "{{status}}"}],
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 3,
      "title": "Request Duration (p95)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"inventory-api\"}[5m])) by (le, handler))", "legendFormat": "p95 {{handler}}"}],
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 12,
      "title": "Request Duration (p50)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "targets": [{"expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"inventory-api\"}[5m])) by (le, handler))", "legendFormat": "p50 {{handler}}"}],
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 5,
      "title": "Process Memory (RSS)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 22},
      "targets": [{"expr": "process_resident_memory_bytes{job=\"inventory-api\"}", "legendFormat": "{{instance}}"}],
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 6,
      "title": "Process CPU Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 22},
      "targets": [{"expr": "rate(process_cpu_seconds_total{job=\"inventory-api\"}[1m])", "legendFormat": "{{instance}}"}],
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    },
    {
      "id": 8,
      "title": "Python GC Collections Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 30},
      "targets": [{"expr": "rate(python_gc_objects_collected_total{job=\"inventory-api\"}[5m])", "legendFormat": "gen{{generation}} {{instance}}"}],
      "datasource": {"type": "prometheus"}
    },
    {
      "id": 9,
      "title": "Open File Descriptors",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 30},
      "targets": [{"expr": "process_open_fds{job=\"inventory-api\"}", "legendFormat": "{{instance}}"}],
      "datasource": {"type": "prometheus"}
    }
  ],
  "time": {"from": "now-30m", "to": "now"},
  "uid": "inventory-system"
}
